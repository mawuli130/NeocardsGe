{
  "entities": {
    "Order": {
      "title": "Order",
      "description": "Represents a card purchase order.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "userName": { "type": "string" },
        "cardId": { "type": "string" },
        "cardName": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "completed", "failed"] },
        "paymentMethod": { "type": "string", "enum": ["crypto", "eversend"] },
        "cryptoCurrency": { "type": "string" },
        "cryptoAddress": { "type": "string" },
        "paymentProof": { "type": "string" },
        "receiptUrl": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" },
        "cardDetails": {
          "type": "object",
          "properties": {
            "number": { "type": "string" },
            "cvv": { "type": "string" },
            "expiry": { "type": "string" },
            "pin": { "type": "string" }
          }
        }
      },
      "required": ["userId", "cardId", "amount", "status", "paymentMethod", "createdAt"]
    },
    "AppSettings": {
      "title": "Global Settings",
      "description": "Payment addresses and global URLs",
      "type": "object",
      "properties": {
        "eversendLink": { "type": "string" },
        "cryptoAddresses": {
          "type": "object",
          "properties": {
            "btc": { "type": "string" },
            "eth": { "type": "string" },
            "usdt": { "type": "string" }
          }
        },
        "contactEmail": { "type": "string" }
      }
    },
    "Card": {
      "title": "Card",
      "description": "Represents a card template for sale",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string" },
        "price": { "type": "number" },
        "limit": { "type": "number" },
        "expiration": { "type": "string" },
        "image": { "type": "string", "description": "URL of the card visual PNG/AVIF" },
        "rating": { "type": "number" },
        "reviews": { "type": "number" },
        "features": { "type": "array", "items": { "type": "string" } }
      }
    }
  },
  "firestore": {
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "User purchases"
    },
    "/cards/{cardId}": {
      "schema": "Card",
      "description": "Products for sale"
    },
    "/assets/{assetId}": {
      "schema": {
        "type": "object",
        "properties": {
          "url": { "type": "string" },
          "type": { "type": "string", "enum": ["card_image"] }
        }
      },
      "description": "Library of images for reuse"
    },
    "/settings/{settingId}": {
      "schema": "AppSettings",
      "description": "Global configuration"
    }
  }
}
